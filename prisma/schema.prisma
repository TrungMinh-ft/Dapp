generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Election {
  id                 Int         @id @default(autoincrement())
  contractElectionId Int         @unique
  proposalCode       String      @default("")
  title              String
  description        String      @default("")
  startTime          BigInt
  endTime            BigInt
  isPublic           Boolean
  isClosed           Boolean
  privacyLevel       String      @default("ENCRYPTED")
  creator            String
  totalVotes         Int         @default(0)
  resultSummary      String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  candidates         Candidate[]
  voteEvents         VoteEvent[]
  authorizedVoters   AuthorizedVoter[]
  eventSyncCursors   EventSyncCursor[]
}

model Candidate {
  id         Int      @id @default(autoincrement())
  electionId Int
  name       String
  index      Int
  voteCount  Int      @default(0)

  election   Election @relation(fields: [electionId], references: [id], onDelete: Cascade)

  @@unique([electionId, index])
}

model VoteEvent {
  id         Int      @id @default(autoincrement())
  electionId Int
  voter      String
  txHash     String?  @unique
  createdAt  DateTime @default(now())

  election   Election @relation(fields: [electionId], references: [id], onDelete: Cascade)
}

model AuthorizedVoter {
  id           Int      @id @default(autoincrement())
  electionId   Int
  wallet       String
  isAuthorized Boolean  @default(true)
  lastTxHash   String?
  updatedAt    DateTime @updatedAt

  election     Election @relation(fields: [electionId], references: [id], onDelete: Cascade)

  @@unique([electionId, wallet])
}

model AdminActionLog {
  id         Int      @id @default(autoincrement())
  action     String
  electionId Int?
  details    String?
  createdAt  DateTime @default(now())
}

model EventSyncCursor {
  id              Int      @id @default(autoincrement())
  electionId      Int
  eventName       String
  lastSyncedBlock Int
  updatedAt       DateTime @updatedAt

  election        Election @relation(fields: [electionId], references: [id], onDelete: Cascade)

  @@unique([electionId, eventName])
}
